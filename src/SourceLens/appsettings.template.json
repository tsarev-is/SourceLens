{
  "AiModel": {
    "Provider": "Claude",
    "Claude": {
      "BinaryPath": "claude",
      "ExtraArgs": ["-p", "--output-format", "text"],
      "DefaultModel": "sonnet",
      "TimeoutSeconds": 300
    },
    "Codex": {
      "BinaryPath": "codex",
      "ExtraArgs": [],
      "DefaultModel": "gpt-5.5",
      "TimeoutSeconds": 300
    }
  },
  "Rag": {
    "Enabled": true,
    "BooksFolder": "./books",
    "TopK": 5,
    "MinScore": 0.75,
    "MaxRelativeScoreDrop": 0.0,
    "CandidatePoolSize": 50,
    "MmrLambda": 0.7,
    "HybridSearch": true,
    "RewriteFollowUpQueries": true,
    "MinQueryLength": 3,
    "ChunkerVersion": "v2",
    "ChunkSize": 250,
    "ChunkOverlap": 50,
    "HistoryDepth": 20,
    "MaxHistoryChars": 13000,
    "EmbeddingProvider": "LocalOnnx",
    "LocalOnnx": {
      "ModelIdLabel": "multilingual-e5-small",
      "Dimensions": 384,
      "MaxSequenceLength": 512
    }
  },
  "Transcription": {
    "Model": "Base",
    "Language": "auto",
    "UseGpu": false,
    "Threads": 4,
    "PoolSize": 1
  },
  "Audio": {
    "SourceName": "default",
    "Rate": 16000,
    "Channels": 1,
    "BitsPerSample": 16
  }
}
