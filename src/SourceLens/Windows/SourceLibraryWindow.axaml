<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="SourceLens.Windows.SourceLibraryWindow"
        Title="Source library"
        Width="820"
        Height="580"
        CanResize="False"
        Background="#1a1d23"
        RequestedThemeVariant="Dark"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <!-- Accent gradient button (Add sources) -->
        <Style Selector="Button.accent">
            <Setter Property="Foreground" Value="#0b1220"/>
            <Setter Property="BorderBrush" Value="#5d9bf2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#5d9bf2" Offset="0"/>
                        <GradientStop Color="#4f7fd6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bordered secondary button (Done / Create / Cancel) -->
        <Style Selector="Button.chip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cdd3dc"/>
            <Setter Property="BorderBrush" Value="#2f3441"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.chip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#222732"/>
        </Style>

        <!-- Header close cross -->
        <Style Selector="Button.headerClose:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#23272f"/>
            <Setter Property="Foreground" Value="#e6e8ec"/>
        </Style>

        <!-- Card remove cross: hover red -->
        <Style Selector="Button.cardDelete:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#26E5534B"/>
            <Setter Property="Foreground" Value="#e5534b"/>
        </Style>
        <!-- Search only this source: hover blue -->
        <Style Selector="Button.cardSearch:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1F6AA6FF"/>
            <Setter Property="Foreground" Value="#6aa6ff"/>
        </Style>

        <!-- Collection sidebar row hover -->
        <Style Selector="Border.collectionRow:pointerover">
            <Setter Property="Background" Value="#20242c"/>
        </Style>
        <!-- Collection delete cross: hover red -->
        <Style Selector="Button.collDelete:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#26E5534B"/>
            <Setter Property="Foreground" Value="#e5534b"/>
        </Style>

        <!-- Dark inline text input (new collection name) -->
        <Style Selector="TextBox.dark">
            <Setter Property="Background" Value="#101216"/>
            <Setter Property="Foreground" Value="#e6e8ec"/>
            <Setter Property="CaretBrush" Value="#e6e8ec"/>
            <Setter Property="BorderBrush" Value="#2a2e37"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="9,6"/>
        </Style>
        <Style Selector="TextBox.dark:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#3a6abf"/>
        </Style>

        <!-- Membership chip (card 'Collections' dropdown) -->
        <Style Selector="Button.memberChip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9aa1ad"/>
            <Setter Property="BorderBrush" Value="#2f3441"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="9,4"/>
        </Style>
        <Style Selector="Button.memberChip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#222732"/>
            <Setter Property="Foreground" Value="#cdd3dc"/>
        </Style>
        <Style Selector="Border.memberRow:pointerover">
            <Setter Property="Background" Value="#222732"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="18,16" BorderBrush="#23262e" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Source library" FontSize="14" FontWeight="Bold" Foreground="#e6e8ec"/>
                    <TextBlock x:Name="LibraryMetaText" FontSize="11.5" Foreground="#7a818d" Margin="0,2,0,0"/>
                </StackPanel>
                <Button x:Name="CloseButton" Grid.Column="1" Classes="headerClose" Content="✕"
                        Background="Transparent" Foreground="#7a818d" BorderThickness="0"
                        FontSize="15" Padding="7,2" CornerRadius="5" VerticalAlignment="Top"
                        Click="CloseButton_OnClick"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="18,13" BorderBrush="#23262e" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button x:Name="AddSourcesButton" Grid.Column="0" Classes="accent" Height="33"
                        Padding="16,0" VerticalContentAlignment="Center"
                        Click="AddSourcesButton_OnClick">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <TextBlock Text="↑" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="Add sources" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="DoneButton" Grid.Column="2" Classes="chip" Content="Done" Height="33"
                        Padding="18,0" VerticalContentAlignment="Center"
                        Click="CloseButton_OnClick"/>
            </Grid>
        </Border>

        <!-- COLLECTIONS sidebar + DOCUMENTS panel -->
        <Grid ColumnDefinitions="208,*">

            <!-- left: collections -->
            <Border Grid.Column="0" Background="#15181d" BorderBrush="#23262e" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Collections" FontSize="9.5" FontWeight="Bold"
                               LetterSpacing="0.6" Foreground="#5b626e" Margin="16,15,16,8"/>

                    <!-- add-new-collection footer -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="12,8,12,14">
                        <Button x:Name="NewCollectionButton" Click="NewCollectionButton_OnClick"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Background="Transparent" Foreground="#7a818d" BorderBrush="#2f3441"
                                BorderThickness="1" CornerRadius="7" FontSize="12" Padding="0,7"
                                Content="+ New collection"/>
                        <StackPanel x:Name="NewCollectionForm" IsVisible="False" Spacing="7">
                            <TextBox x:Name="NewCollectionBox" Classes="dark" Watermark="Collection name"
                                     KeyDown="NewCollectionBox_OnKeyDown"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="7">
                                <Button x:Name="CreateCollectionButton" Grid.Column="0" Classes="accent" Height="29"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Content="Create" Click="CreateCollectionButton_OnClick"/>
                                <Button x:Name="CancelCollectionButton" Grid.Column="1" Classes="chip" Height="29"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Content="Cancel" Click="CancelCollectionButton_OnClick"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="CollectionsPanel" Margin="8,0,8,8" Spacing="1"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- right: documents -->
            <DockPanel Grid.Column="1">
                <TextBlock x:Name="DocsHeaderText" DockPanel.Dock="Top" FontSize="12.5" FontWeight="SemiBold"
                           Foreground="#dfe3ea" Margin="18,16,18,10"/>
                <Panel>
                    <TextBlock x:Name="EmptyText" Text="No sources indexed yet" IsVisible="False"
                               FontSize="12.5" Foreground="#454c58"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <ScrollViewer Padding="18,0,18,16" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DocsPanel" Spacing="8"/>
                    </ScrollViewer>
                </Panel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
