<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="SourceLens.Windows.MainWindow"
        Title="SourceLens · Configuration error"
        Background="#16181d"
        MinHeight="280"
        MinWidth="560"
        Width="640"
        Height="320"
        WindowStartupLocation="CenterScreen">
    <Border Background="#13151a" BorderBrush="#23262e" BorderThickness="1" CornerRadius="8" Margin="16" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
            <TextBlock Grid.Row="0"
                       Text="SourceLens failed to start"
                       Foreground="#e5534b"
                       FontSize="18"
                       FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1"
                       Text="The configuration is invalid or a startup component failed."
                       Foreground="#6b7280"
                       Margin="0 6 0 12"/>
            <TextBox Grid.Row="2"
                     x:Name="ErrorTextBox"
                     Background="#101216"
                     Foreground="#e6e8ec"
                     BorderBrush="#2a2e37"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"/>
            <TextBlock Grid.Row="3"
                       Text="Fix appsettings.json next to the binary and restart. Details: logs/Error.log"
                       Foreground="#6b7280"
                       Margin="0 12 0 0"/>
        </Grid>
    </Border>
</Window>
