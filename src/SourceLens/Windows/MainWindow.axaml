<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="SourceLens.Windows.MainWindow"
        Title="SourceLens"
        MinHeight="450"
        MinWidth="800"
        Width="920"
        Height="450">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель: статус и кнопки -->
        <DockPanel Grid.Row="0" HorizontalAlignment="Stretch">
            <TextBlock VerticalAlignment="Center" Text="Статус:" FontWeight="Bold"/>
            <TextBlock x:Name="StatusTextBox" VerticalAlignment="Center" Text="Готов" Margin="3 0 3 0" Foreground="DarkGreen"/>
            <Button x:Name="ButtonRunRequest" DockPanel.Dock="Right" Content="Сделать запрос" HorizontalContentAlignment="Center" HorizontalAlignment="Right" Width="150" Click="ButtonRequest_OnClick"/>
        </DockPanel>

        <!-- Основная область -->
        <TextBox Grid.Row="1" x:Name="AnswerTextBox"
                 Text=""
                 Watermark="Ответ появится здесь"
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 Margin="0 10 0 0"
                 TextWrapping="Wrap"/>
    </Grid>
</Window>
